{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build midi-time-machine",
            "type": "shell",
            "command": "make",
            "options": {
                "cwd": "${workspaceFolder}/midi-time-machine/Builds/LinuxMakefile"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": "$gcc"
        }
    ]
}